TAVILY_API_KEY=
NOVA_ACT_API_KEY=
NOVA_ACT_CHROME_CHANNEL=chrome
NOVA_ACT_HEADLESS=false
NOVA_ACT_LOGS_DIR=
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_SIMPLE_MODEL=llama-3.1-8b-instant
GROQ_MEMORY_MODEL=llama-3.3-70b-versatile
GROQ_COMPLEX_MODEL=llama-3.3-70b-versatile
GROQ_CODE_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=60

NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_SIMPLE_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_MEMORY_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_COMPLEX_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_CODE_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_TIMEOUT_SECONDS=120

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SIMPLE_MODEL=openrouter/free
OPENROUTER_MEMORY_MODEL=openrouter/free
OPENROUTER_COMPLEX_MODEL=openrouter/free
OPENROUTER_CODE_MODEL=openrouter/free
OPENROUTER_TIMEOUT_SECONDS=120

BROWSER_DEFAULT_TIMEOUT_MS=15000
BROWSER_EXTRACT_MAX_CHARS=12000

STT_ENABLED=true
STT_MODEL=tiny
STT_SAMPLE_RATE=16000
STT_INPUT_DEVICE=
STT_SILENCE_THRESHOLD=0.015
STT_SILENCE_DURATION_SECONDS=1.5
STT_MAX_RECORD_SECONDS=20

WAKE_WORD_ENABLED=false
WAKE_WORD_KEYWORD=jarvis
WAKE_WORD_MODEL_PATH=
WAKE_WORD_INPUT_DEVICE=
WAKE_WORD_THRESHOLD=0.2
WAKE_WORD_VAD_THRESHOLD=0.0

AUDIO_FEEDBACK_ENABLED=true
TTS_ENABLED=true
TTS_VOICE=en-US-GuyNeural
TTS_RATE=+0%
TTS_VOLUME=+0%

OPENWEATHERMAP_API_KEY=
WEATHER_UNITS=metric

REMINDER_CHECK_SECONDS=30
REMINDER_TIMEZONE=Asia/Calcutta

GMAIL_CLIENT_SECRET_FILE=
CALENDAR_CLIENT_SECRET_FILE=
GMAIL_TOKEN_FILE=C:\path\to\jarvis\config\google\gmail_token.json
CALENDAR_TOKEN_FILE=C:\path\to\jarvis\config\google\calendar_token.json
